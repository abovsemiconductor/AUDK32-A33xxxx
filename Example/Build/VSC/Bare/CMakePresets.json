        },
        {
            "name": "A33G53x",
            "inherits": "AUDK32",
            "cacheVariables": {
                "AUDK32_TARGET": "A33G53x",
                "TARGET_BOARD":"A33G539-VLN"
            }
        },
        {
            "name": "A33M11x",
            "inherits": "AUDK32",
            "cacheVariables": {
                "AUDK32_TARGET": "A33M11x",
                "TARGET_BOARD":"A33M116-RLN"
            }
        }
    ]
