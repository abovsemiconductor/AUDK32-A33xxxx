{
    "version": 3,
    "configurePresets": [
        {
            "name": "AUDK32",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "generator": "Ninja",
            "environment": {
                "PATH": "${sourceDir}/../../../../Tool/Ninja;$penv{PATH}"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../toolchain-gcc.cmake",
                "PROJECT":"Bare",
                "PRODUCT":"A33xxxx"
