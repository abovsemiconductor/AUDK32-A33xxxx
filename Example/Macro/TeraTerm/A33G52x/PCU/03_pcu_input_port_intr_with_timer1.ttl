; A. Description
;    A list of commands here configures PCU module and generates input interrupt via the signal from timer1.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. Timer1
;
; D. Default Port
;    1. PCU     : PA0 (Input)
;                 PA1 (Input)
;                 PB2 (Input)
;    2. Timer10 : PB0 (Output)
;                 PA6 (Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PB0 (Timer10 Output) ----> PA0 (Input)
;                            ----> PA1 (Input)
;                            ----> PB2 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PA0/PA1/PB2)
; 1. Port Group                   : 0 (PCU Port A)
;                                 : 1 (PCU Port B)
;
; 2. Port                         : [ 0 0 i i -intr i e r ] [ 0 1 i i -intr i e r ] [ 1 2 i i -intr i e r ]
;    Pin Number                   : 0 / 1 / 2
;    Pin Mode                     : i (Input)
;    Pin Input Mode               : i (Normal Input)
;    Pin Operation Mode           : i (Interrupt)
;    Pin Interrupt Mode           : e (Edge)
;    Pin Interrupt Trigger Edge   : r (Rising)
;
; Timer10
; 1. Channel                      : 0 (Timer10)
;
; 2. Clock                        : [ 0 p 16 999 ]
;    Source                       : p (PCLK : Peripherl Clock)
;    Source Divide                : 16
;    Timer1 Pre-Divide            : 999 (MCCR Clock) / (Pre-Divide + 1)
;
; 3. Config                       : [ 0 i p h 1000 1000 ]
;    Operation                    : i (Interrupt)
;    Mode                         : p (Period)
;    Output Port Polarity         : h (High)
;    A Data                       : 1000
;    B Data                       : 1000
;
; PCU (PB0)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 0 a 1 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T11O)
;
; PCU (PA0)
sendln 'cm pcu'
mpause 30
sendln 'port 0 0 i i -intr i e r'
mpause 30

; PCU (PA1)
sendln 'port 0 1 i i -intr i e r'
mpause 30

; PCU (PB2)
sendln 'port 1 2 i i -intr i e r'
mpause 30

; PCU (PB0)
sendln 'port 1 0 a 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 16 999'
mpause 30
sendln 'config 0 i p h 1000 1000'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
