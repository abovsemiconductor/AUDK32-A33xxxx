; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA0 (AN0)
;               : PA1 (AN1)
;               : PA2 (AN2)
;    2. Timer10 : PB0 (Output)
;                 PA6 (Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PA1 (AN1) <----> PB0 (Timer10 Output)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 255 ]
;    Source                     : p (Periperhal Clock)
;    Source Divide              : 255 (Divide + 1)
;
; 3. Config                     : [ config 0 i i ]
;    Operation                  : i (Interrupt)
;    Reference Level            : i (Internal VDD)
;
; 4. Seq                        : [ 0 a 1 ]
;    Trigger Source             : a (ADC Instant Start)
;    Input Channel              : 1
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 p 16 9 ]
;    Source                    : p (PCLK : Peripherl Clock)
;    Source Divide             : 16
;    Timer1 Pre-Divide         : 999 (MCCR Clock) / (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i p h 10 10 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 10
;    B Data                    : 10
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 3 ] [ 0 1 a 3 ] [ 0 2 a 3 ]
;    Pin Number                : 0 / 1 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (AN0/AN1/AN2)
; 
; 3. Port                      : [ 0 0 i a ] [ 0 1 i a ] [ 0 2 i a ]
;    Pin Number                : 0 / 1 / 2
;    Pin Mode                  : i (Input)
;    Pin Input Mode            : a (Analog Input)
;
; PCU (PB0)
; 1. Port Group                 : 1 (PCU Port B)
;
; 2. Port                       : [ 1 0 a 1 ]
;    Pin Number                 : 1
;    Pin Mode                   : a (Alternative)
;    Alternative                : 0 (T10O)

; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 0 a 3'
mpause 30
sendln 'port 0 1 a 3'
mpause 30
sendln 'port 0 2 a 3'
mpause 30
sendln 'port 0 0 i a'
mpause 30
sendln 'port 0 1 i a'
mpause 30
sendln 'port 0 2 i a'
mpause 30

; PCU (PB0)
sendln 'cm pcu'
mpause 30
sendln 'port 1 0 a 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 16 9'
mpause 30
sendln 'config 0 i p h 10 10'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'

; ADC0
mpause 30
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 255'
mpause 30
sendln 'config 0 i i'
mpause 30
sendln 'seq 0 a 1'
mpause 30
sendln 'start 0'
pause 2 
sendln 'dump 0'
pause 3
